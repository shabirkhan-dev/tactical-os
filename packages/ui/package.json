{
	"name": "@school-os/ui",
	"version": "0.0.0",
	"private": true,
	"sideEffects": ["**/*.css"],
	"type": "module",
	"exports": {
		"./globals.css": "./src/styles/globals.css",
		"./components/*": "./src/components/*.tsx",
		"./lib/*": "./src/lib/*.ts",
		"./hooks/*": "./src/hooks/*.ts",
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"typecheck": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.6.0",
		"@hugeicons/core-free-icons": "^4.1.4",
		"@hugeicons/react": "^1.1.6",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"recharts": "^3.9.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"vaul": "^1.1.2"
	},
	"devDependencies": {
		"@school-os/typescript-config": "workspace:*",
		"@types/react": "^19.2.14",
		"typescript": "^6.0.3"
	},
	"peerDependencies": {
		"next-themes": ">=0.4",
		"react": ">=19",
		"react-dom": ">=19"
	}
}
