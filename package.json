{
  "name": "school-os",
  "version": "0.1.0",
  "private": true,
  "license": "MIT OR Apache-2.0",
  "packageManager": "bun@1.3.13",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev --continue --filter=!rust --concurrency=12",
    "dev:rust": "bun --cwd apps/rust run dev",
    "dev:ai": "bun --cwd apps/ai-api run dev",
    "dev:all": "turbo run dev --continue --concurrency=12",
    "build": "turbo run build",
    "start": "turbo run start",
    "preflight": "bun run lint && bun run typecheck && bun run test",
    "lint": "turbo run lint && bun run scripts:lint",
    "lint:fix": "turbo run lint:fix",
    "format": "biome format --write . && bun run scripts:format && (cd apps/rust && cargo fmt || true)",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && bun run test:scripts",
    "test:coverage": "(cd apps/web && bun run test:coverage) && (cd apps/nest-api && bun run test:cov) && (cd packages/logger && bun run test:coverage) && (cd apps/mobile && bun run test) && (cd apps/rust && bun run test) && bun run test:scripts",
    "test:scripts": "bash scripts/bash/tests/main.test.sh && python -m unittest scripts/python/tests/test_main.py",
    "test:e2e:web": "cd apps/web && bun run test:e2e",
    "architecture:check": "bash scripts/architecture/check-boundaries.sh",
    "ci:lint": "bun run lint && bun run architecture:check",
    "ci:typecheck": "bun run typecheck",
    "ci:test": "bun run test:coverage",
    "ci:e2e:web": "bun run test:e2e:web",
    "scripts:lint": "shellcheck scripts/bash/*.sh scripts/git-hooks/*.sh && (ruff check scripts/python 2>/dev/null || true)",
    "scripts:format": "shfmt -i 4 -w scripts/bash/*.sh scripts/git-hooks/*.sh || true",
    "scripts:run": "bash scripts/bash/main.sh",
    "scripts:run:bash": "bash scripts/bash/main.sh",
    "scripts:run:python": "python scripts/python/main.py",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "lefthook": "^2.1.6",
    "lightningcss": "1.32.0",
    "turbo": "^2.9.14"
  },
  "ignoreScripts": ["sharp", "unrs-resolver"],
  "trustedDependencies": ["sharp", "unrs-resolver"],
  "overrides": {
    "lightningcss": "1.32.0",
    "@expo/dom-webview": "57.0.0",
    "@expo/log-box": "57.0.0",
    "@expo/metro-runtime": "57.0.3",
    "expo": "57.0.4",
    "expo-constants": "57.0.3",
    "expo-font": "57.0.0",
    "expo-glass-effect": "57.0.0",
    "expo-linking": "57.0.2",
    "expo-symbols": "57.0.0"
  }
}
