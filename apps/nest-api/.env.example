# PostgreSQL / Neon. Neon URLs automatically enable TLS.
DATABASE_URL=postgresql://school-os:school-os@localhost:5433/school-os
DATABASE_POOL_MAX=10
# DATABASE_SSL=true

# Use independent 32+ character secrets in production.
JWT_SECRET=development-only-jwt-secret-change-me
AUTH_TOKEN_SECRET=development-only-auth-token-secret-change-me
JWT_ACCESS_EXPIRES_IN=15m
SESSION_TTL_DAYS=30
MAGIC_LINK_TTL_MINUTES=15
MFA_CHALLENGE_TTL_MINUTES=5

PORT=4000
APP_NAME=Tactical OS
WEB_APP_URL=http://localhost:3000
# Comma-separated. Include both localhost and 127.0.0.1 — browsers treat them as different origins.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3002,http://127.0.0.1:3002,http://localhost:8081,http://localhost:8082,http://127.0.0.1:8081,http://127.0.0.1:8082
REFRESH_COOKIE_NAME=tactical_os_refresh_token
# COOKIE_DOMAIN=.example.com
# Required for Vercel web ↔ Render API (cross-site cookies). Keep lax for same-origin local/Docker.
# COOKIE_SAME_SITE=none
# TRUST_PROXY=true

# Development only: return OTPs in API responses when no email provider is configured.
AUTH_DEV_EXPOSE_CODES=true

# Required in production for verification and password-reset messages.
# RESEND_API_KEY=re_...
# Development: onboarding@resend.dev can only send to your Resend account email.
# Production: replace it with an address on a domain verified in Resend.
AUTH_EMAIL_FROM=Tactical OS <onboarding@resend.dev>

# Optional authentication providers.
WEBAUTHN_RP_ID=localhost
# Comma-separated origins (web + native). Add android:apk-key-hash:... for Android passkeys.
WEBAUTHN_ORIGIN=http://localhost:3000
# GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Billing (Stripe + Razorpay). Leave unset until you are ready to test checkout.
BILLING_DEFAULT_PROVIDER=stripe
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_TEAM_MONTHLY=price_...
# STRIPE_PRICE_TEAM_YEARLY=price_...
# STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
# STRIPE_PRICE_ENTERPRISE_YEARLY=price_...
# RAZORPAY_KEY_ID=rzp_test_...
# RAZORPAY_KEY_SECRET=...
# RAZORPAY_WEBHOOK_SECRET=...
# RAZORPAY_PLAN_TEAM_MONTHLY=plan_...
# RAZORPAY_PLAN_TEAM_YEARLY=plan_...
# RAZORPAY_PLAN_ENTERPRISE_MONTHLY=plan_...
# RAZORPAY_PLAN_ENTERPRISE_YEARLY=plan_...

# AI assistance (Nest → apps/ai-api). Browser never calls FastAPI directly.
AI_API_URL=http://localhost:8000
AI_SERVICE_TOKEN=development-only-ai-service-token-change-me
