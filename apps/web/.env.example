# NestJS API base URL (no trailing path). Production: your Render service origin.
# Prefer 127.0.0.1 locally on Windows (avoids IPv6 localhost connection refused).
NEXT_PUBLIC_NEST_API_URL=http://127.0.0.1:4000

# Optional. Must match GOOGLE_CLIENT_ID in the Nest API.
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
