# Nest API base URL (no path). Required on a physical phone — localhost will hang.
# Use your computer's LAN IP (same Wi-Fi as the phone), e.g.:
# EXPO_PUBLIC_NEST_API_URL=http://10.235.88.139:4000
#
# If unset, the app auto-uses Metro's host (Expo LAN) or Android emulator 10.0.2.2.
EXPO_PUBLIC_NEST_API_URL=http://10.235.88.139:4000
