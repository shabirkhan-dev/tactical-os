{
	"name": "fastapi",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "uv run fastapi dev src/main.py --host 0.0.0.0 --port 8000",
		"start": "uv run uvicorn main:app --app-dir src --host 0.0.0.0 --port 8000",
		"build": "uv sync",
		"lint": "uv run ruff check .",
		"lint:fix": "uv run ruff check --fix .",
		"format": "uv run ruff format .",
		"test": ".venv/bin/pytest"
	}
}
