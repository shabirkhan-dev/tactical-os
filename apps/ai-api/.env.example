# FastAPI AI service. Nest calls this server-to-server only.
APP_NAME=school-os-ai-api
ENVIRONMENT=development
PORT=8000
API_PREFIX=/api/v1

# Shared with Nest AI_SERVICE_TOKEN. Required in production.
AI_SERVICE_TOKEN=development-only-ai-service-token-change-me

# mock | openai_compatible
AI_PROVIDER=mock
# Required when AI_PROVIDER=openai_compatible
# OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Bound CORS — prefer Nest-only calls (no browser direct access).
CORS_ORIGINS=http://localhost:4000
