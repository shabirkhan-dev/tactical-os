{
	"name": "hono-api",
	"scripts": {
		"dev": "bun run --hot src/server.ts",
		"postinstall": "prisma generate",
		"db:generate": "prisma generate",
		"db:push": "prisma db push",
		"db:migrate": "prisma migrate dev",
		"db:studio": "prisma studio",
		"start": "prisma db push && bun run src/server.ts",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest"
	},
	"dependencies": {
		"@prisma/adapter-pg": "^7.8.0",
		"@prisma/client": "^7.8.0",
		"@school-os/logger": "workspace:*",
		"bcryptjs": "^3.0.3",
		"hono": "^4.12.19",
		"jose": "^6.2.3",
		"otplib": "^13.4.0",
		"pg": "^8.20.0",
		"qrcode": "^1.5.4",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/bcryptjs": "^3.0.0",
		"@types/bun": "^1.3.14",
		"@types/qrcode": "^1.5.5",
		"prisma": "^7.8.0",
		"@vitest/coverage-v8": "^4.1.6",
		"vitest": "^4.1.6"
	}
}
