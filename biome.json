{
	"$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"apps/**/*.ts",
			"apps/**/*.tsx",
			"packages/**/*.ts",
			"packages/**/*.tsx",
			"*.config.ts",
			"*.config.mjs",
			"!**/.next",
			"!**/dist"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"useExhaustiveDependencies": "error",
				"useHookAtTopLevel": "error"
			},
			"performance": {
				"noImgElement": "warn"
			},
			"style": {
				"noHeadElement": "warn",
				"useNodejsImportProtocol": "warn"
			},
			"suspicious": {
				"noDocumentImportInPage": "error",
				"noHeadImportInDocument": "error",
				"useGoogleFontDisplay": "warn"
			}
		},
		"domains": {
			"next": "recommended",
			"react": "recommended"
		}
	},
	"overrides": [
		{
			"includes": ["apps/nest-api/**/*.ts"],
			"javascript": {
				"parser": {
					"unsafeParameterDecoratorsEnabled": true
				},
				"formatter": {
					"quoteStyle": "single",
					"trailingCommas": "all"
				}
			},
			"linter": {
				"domains": {
					"next": "none",
					"react": "none"
				},
				"rules": {
					"style": {
						"useImportType": "off",
						"useNodejsImportProtocol": "error"
					},
					"suspicious": {
						"noExplicitAny": "off",
						"noDocumentImportInPage": "off",
						"noHeadImportInDocument": "off",
						"useGoogleFontDisplay": "off"
					},
					"performance": {
						"noImgElement": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off",
						"useHookAtTopLevel": "off",
						"noNextAsyncClientComponent": "off"
					},
					"nursery": {
						"noFloatingPromises": "warn",
						"noMisusedPromises": "warn",
						"noBeforeInteractiveScriptOutsideDocument": "off"
					}
				}
			}
		},
		{
			"includes": [
				"apps/web/**/*.ts",
				"apps/web/**/*.tsx",
				"apps/docs/**/*.ts",
				"apps/docs/**/*.tsx"
			],
			"linter": {
				"domains": {
					"next": "recommended",
					"react": "recommended"
				},
				"rules": {
					"correctness": {
						"noNextAsyncClientComponent": "warn"
					},
					"nursery": {
						"noBeforeInteractiveScriptOutsideDocument": "warn"
					}
				}
			}
		},
		{
			"includes": ["apps/mobile/**/*.ts", "apps/mobile/**/*.tsx"],
			"linter": {
				"domains": {
					"next": "none"
				},
				"rules": {
					"suspicious": {
						"noArrayIndexKey": "off",
						"noDocumentImportInPage": "off",
						"noHeadImportInDocument": "off"
					},
					"performance": {
						"noImgElement": "off"
					},
					"style": {
						"noHeadElement": "off"
					},
					"correctness": {
						"noNextAsyncClientComponent": "off"
					},
					"nursery": {
						"noBeforeInteractiveScriptOutsideDocument": "off"
					}
				}
			}
		}
	]
}
